[Unit]
Description=Scoreboard Flask App
After=network.target postgresql.service

[Service]
Type=simple
User=liam
WorkingDirectory=/home/liam/coding/scoreboard-site/score.liamis.dev
ExecStart=/home/liam/coding/scoreboard-site/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
